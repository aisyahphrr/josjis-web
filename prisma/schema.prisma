generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
  DRIVER
  UMKM
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  WAITING_DRIVER
  ASSIGNED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

enum VehicleType {
  MOTORBIKE
  CAR
  VAN
  PICKUP
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  passwordHash     String
  name             String
  phone            String?
  image            String?
  role             UserRole
  isActive         Boolean         @default(true)
  emailVerified    DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  accounts         Account[]
  sessions         Session[]
  adminProfile     AdminProfile?
  customerProfile  CustomerProfile?
  driverProfile    DriverProfile?
  umkmProfile      UmkmProfile?
  products         Product[]       @relation("UmkmProducts")
  buyerOrders      Order[]         @relation("BuyerOrders")
  assignedDelivery Delivery[]      @relation("AssignedDriver")
  soldOrderItems   OrderItem[]     @relation("SellerOrderItems")
  buyerThreads     ChatThread[]    @relation("BuyerThreads")
  sellerThreads    ChatThread[]    @relation("SellerThreads")
  sentMessages     ChatMessage[]   @relation("ChatSender")
  authoredArticles Article[]       @relation("ArticleAuthor")
}

model AdminProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  defaultAddress  String?
  loyaltyPoints   Int      @default(0)
  preferredRegion String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriverProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  vehicleType    VehicleType
  licensePlate   String?
  isAvailable    Boolean        @default(true)
  currentCity    String?
  approvalStatus ApprovalStatus @default(PENDING)
  verifiedAt     DateTime?
  rejectionReason String?
  ratingAverage  Float          @default(5)
  totalDeliveries Int           @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UmkmProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  businessName     String
  businessSlug     String          @unique
  description      String?
  city             String?
  district         String?
  address          String?
  approvalStatus   ApprovalStatus  @default(PENDING)
  verifiedAt       DateTime?
  rejectionReason  String?
  ratingAverage    Float           @default(5)
  totalProducts    Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id            String      @id @default(cuid())
  sellerId      String
  name          String
  slug          String      @unique
  description   String
  priceInIdr    Int
  stock         Int         @default(0)
  imageUrl      String?
  isFeatured    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  seller        User        @relation("UmkmProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
}

model Order {
  id               String         @id @default(cuid())
  buyerId          String
  status           OrderStatus    @default(PENDING)
  paymentStatus    PaymentStatus  @default(UNPAID)
  totalAmountInIdr Int
  shippingAddress  String
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  buyer            User           @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  items            OrderItem[]
  delivery         Delivery?
  chatThreads      ChatThread[]
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String
  sellerId       String
  quantity       Int
  unitPriceInIdr Int
  subtotalInIdr  Int
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  seller         User     @relation("SellerOrderItems", fields: [sellerId], references: [id], onDelete: Restrict)
}

model Delivery {
  id              String         @id @default(cuid())
  orderId         String         @unique
  driverId        String?
  status          DeliveryStatus @default(WAITING_DRIVER)
  trackingCode    String?        @unique
  pickupAddress   String?
  dropoffAddress  String?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver          User?          @relation("AssignedDriver", fields: [driverId], references: [id], onDelete: SetNull)
}

model ChatThread {
  id            String        @id @default(cuid())
  buyerId       String
  sellerId      String
  orderId       String?
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  buyer         User          @relation("BuyerThreads", fields: [buyerId], references: [id], onDelete: Cascade)
  seller        User          @relation("SellerThreads", fields: [sellerId], references: [id], onDelete: Cascade)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages      ChatMessage[]

  @@index([buyerId, sellerId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  body      String
  createdAt DateTime @default(now())
  readAt    DateTime?
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User       @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Article {
  id          String        @id @default(cuid())
  authorId    String
  slug        String        @unique
  title       String
  excerpt     String?
  coverImage  String?
  content     String
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  author      User          @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  type      String   @default("email_verify")  // email_verify, password_reset
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
